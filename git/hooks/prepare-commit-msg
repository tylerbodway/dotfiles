#!/usr/bin/env bash
set -e

# Delegation shim: forwards to repo-local prepare-commit-msg hook if it exists.
# Required because core.hooksPath overrides per-repo .git/hooks/.

LOCAL_HOOK="$(git rev-parse --git-dir)/hooks/prepare-commit-msg"
if [ -x "${LOCAL_HOOK}" ]; then
  exec "${LOCAL_HOOK}" "$@"
fi
