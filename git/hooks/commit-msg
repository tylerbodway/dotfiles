#!/usr/bin/env bash
set -e

# Append Co-Authored-By trailer for AI-assisted commits (tracked by Swarmia).
# Skipped if the trailer already exists (e.g., OpenCode added it).
# To commit without the trailer, use --no-verify (lazygit: 'w' key).

TRAILER="Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>"

if ! grep -qF "${TRAILER}" "$1"; then
  git interpret-trailers --in-place --trailer "${TRAILER}" "$1"
fi

# Delegate to repo-local commit-msg hook if it exists.
LOCAL_HOOK="$(git rev-parse --git-dir)/hooks/commit-msg"
if [ -x "${LOCAL_HOOK}" ]; then
  exec "${LOCAL_HOOK}" "$@"
fi
