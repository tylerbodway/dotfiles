{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "planning-center": {
      "npm": "@ai-sdk/anthropic",
      "name": "Planning Center",
      "models": {
        "claude-fable-5": {
          "name": "Claude Fable 5",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "claude-sonnet-5": {
          "name": "Claude Sonnet 5",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 1000000,
            "output": 128000,
          },
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "limit": {
            "context": 200000,
            "output": 64000,
          },
        },
      },
    },
  },
  "model": "planning-center/claude-opus-4-6",
  "small_model": "planning-center/claude-haiku-4-5",
  "agent": {
    "explore": {
      "model": "planning-center/claude-sonnet-5",
    },
  },
  "mcp": {
    "linear": {
      // project management
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false,
    },
    "notion": {
      // documentation
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false,
    },
    "redshift": {
      // business intelligence
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "{env:HOME}/Code/mcp-servers/redshift",
        "run",
        "awslabs.redshift-mcp-server",
      ],
      "environment": {
        "AWS_PROFILE": "pco-bi-query",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "WARNING",
      },
      "enabled": false,
    },
  },
  "permission": {
    "bash": {
      "box *": "ask",
      "box uninstall *": "deny",
      "pco *": "ask",
      "pco connect *": "deny",
      "pco console *": "deny",
      "pco dbconnect *": "deny",
      "pco ssm *": "deny",
    },
    "external_directory": {
      "~/Code/*": "allow",
    },
  },
}
