{
  "$schema": "https://opencode.ai/config.json",
  "theme": "vague",
  "autoupdate": false,
  "model": "opencode/glm-5.2",
  "small_model": "opencode/deepseek-v4-flash-free",
  "agent": {
    "explore": {
      "model": "opencode/kimi-k2.7-code",
    },
    "general": {
      "model": "opencode/kimi-k2.7-code",
    },
  },
  "lsp": {
    "herb": {
      "command": ["herb-language-server", "--stdio"],
      "extensions": [".erb", ".html"],
    },
    "jsonls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"],
    },
    "stylelint": {
      "command": ["stylelint-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"],
    },
  },
  "formatter": {
    "herb": {
      "command": ["herb-format", "$FILE"],
      "extensions": [".erb"],
    },
    "rubocop": {
      "disabled": true, // avoids conflict with rubotree
    },
    "rubotree": {
      // sequential rubocop/syntax_tree formatting
      "command": ["rubotree", "$FILE"],
      "extensions": [".rb", ".rake", ".gemspec", ".ru"],
    },
    "stylelint": {
      "command": ["stylelint", "--fix", "$FILE"],
      "extensions": [".css", ".scss", ".less"],
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"],
    },
  },
  "mcp": {
    "devtools": {
      // agentic browser navigation, console, and screenshots
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
        "--no-usage-statistics",
        "--user-data-dir={env:XDG_STATE_HOME}/opencode/brave-profile",
      ],
      "enabled": false,
    },
  },
  "permission": {
    "bash": {
      "*": "allow",
      "brew *": "ask",
      "bunx *": "deny",
      "chmod *": "ask",
      "curl *": "deny",
      "git clean *": "ask",
      "git push *": "deny",
      "git reset *": "ask",
      "nc *": "deny",
      "netcat *": "deny",
      "npm *": "ask",
      "npx *": "deny",
      "pnpx *": "deny",
      "rm *": "ask",
      "scp *": "deny",
      "sftp *": "deny",
      "ssh *": "deny",
      "su *": "deny",
      "sudo *": "deny",
      "wget *": "deny",
      "yarn *": "ask",
      "yarn dlx *": "deny",
      "yarn lint *": "allow",
      "yarn test *": "allow",
    },
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      ".env.local": "deny",
      "secrets/**": "deny",
      ".secrets/**": "deny",
      "credentials*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*_rsa": "deny",
      "*_dsa": "deny",
      "*_ecdsa": "deny",
      "*_ed25519": "deny",
      ".ssh/**": "deny",
    },
    "edit": {
      "*": "ask",
      ".env": "deny",
      ".env.*": "deny",
      ".env.local": "deny",
      "secrets/**": "deny",
      ".secrets/**": "deny",
      "credentials*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      ".opencode/**": "allow",
      ".docs/**": "allow",
      "/var/folders/kx/rzzvcjgj1t9_z8h1s58k2phw0000gn/T/opencode/*": "allow",
    },
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3", // aligns column widths
    "@tarquinen/opencode-dcp@3.1.13", // dynamic context pruning
    "opencode-pty@0.3.2", // background processes
  ],
}
