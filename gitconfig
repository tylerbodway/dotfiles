[alias]
  co = checkout
  cp = cherry-pick
  unstage = reset HEAD --
  last = log -1 HEAD
  st = status
  stashdiff = stash show -p
  qlog = log --oneline --decorate --graph -15
  irb = rebase -i
[commit]
  verbose = true
  gpgsign = true
[core]
  excludesFile = ~/.gitignore
  pager = less -F -X
[diff]
  noprefix = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[gpg]
  format = ssh
[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[init]
  defaultBranch = main
[pull]
  rebase = false
[rebase]
  autosquash = true
[user]
  name = Tyler Bodway
  email = 9326912+tylerbodway@users.noreply.github.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMn/Rl7U44dZDp2ak/X84DwYxxTn5xl3Sf8SAivxd0nf
[includeIf "gitdir:~/Code/"]
  path = ~/Code/.gitconfig_include
[blame]
  ignoreRevsFile = .git-blame-ignore-revs
